# Hermes BEAM environment
# Copy to .env for local development. Do not commit real secrets.

# Runtime state root. Defaults to ~/.hermes when unset.
HERMES_HOME=~/.hermes

# OpenAI-compatible LLM endpoint. OpenRouter is the default-style deployment.
HERMES_API_KEY=
HERMES_BASE_URL=https://openrouter.ai/api/v1
HERMES_MODEL=openai/gpt-4o-mini

# Backward-compatible provider fallbacks read by Hermes BEAM when HERMES_* is unset.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Token and streaming controls.
HERMES_TOKEN_BUDGET=200000
HERMES_STREAM_TIMEOUT_MS=120000
HERMES_FALLBACK_MODELS=

# Optional subsystems. Leave disabled unless explicitly needed.
HERMES_ENABLE_SKILL_SYNTHESIS=false
HERMES_ENABLE_SEMANTIC_SEARCH=false
# One of: empty/none/disabled, gleamdb, honcho, mem0, supermemory.
HERMES_MEMORY_BACKEND=

# Vector memory backend for semantic search.
# Options: api (OpenAI embeddings), hash (local offline), disabled.
HERMES_VECTOR_BACKEND=api

# Context window and auto-compaction.
HERMES_CONTEXT_WINDOW=200000
HERMES_COMPACTION_SOFT_PCT=65
HERMES_COMPACTION_HARD_PCT=90

# Discord gateway. Required for `make discord` or `gleam run -- --discord`.
HERMES_DISCORD_TOKEN=
HERMES_DISCORD_CHANNEL_IDS=
HERMES_DISCORD_ALLOWED_USERS=
HERMES_DISCORD_RESPOND_TO=mention

# A2A Protocol server. Required for `make a2a` or `gleam run -- --a2a`.
HERMES_A2A_PORT=8080

# Auto-update. Checks GitHub releases on startup when enabled.
HERMES_AUTO_UPDATE=false
HERMES_VERSION=2.0.0

# Telegram gateway. Required for `make telegram` or `gleam run -- --telegram`.
HERMES_TELEGRAM_TOKEN=
# Comma-separated Telegram user IDs/usernames allowed to use the gateway.
# `GATEWAY_ALLOWED_USERS` is also recognized by shared gateway tooling.
HERMES_TELEGRAM_ALLOWED_USERS=
GATEWAY_ALLOWED_USERS=
HERMES_GATEWAY_LOCK_PORT=8765

# Worker and tool integration.
HERMES_WORKERS_DIR=../babashka_workers
# Optional MCP command launched by Hermes BEAM, for example: `node ./server.js`.
HERMES_MCP_CMD=
# Optional command allowlist used by Babashka workers when enabled.
HERMES_WORKER_SHELL_ALLOWLIST=
HERMES_GIT_BASH_PATH=

# Data/catalog roots. Leave blank to use bundled repository defaults.
HERMES_BUNDLED_SKILLS=
HERMES_OPTIONAL_SKILLS=
HERMES_OPTIONAL_MCPS=

# Time handling.
HERMES_TIMEZONE=UTC
