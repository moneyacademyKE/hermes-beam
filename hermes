#!/usr/bin/env bb

(require '[babashka.process :as proc]
         '[babashka.fs :as fs])

(defn print-help []
  (println "Hermes BEAM CLI Launcher")
  (println "Usage:")
  (println "  ./hermes              - Start the interactive REPL (default)")
  (println "  ./hermes --onboard    - Run configuration wizard")
  (println "  ./hermes --doctor     - Run diagnostics")
  (println "  ./hermes --version    - Show version")
  (println "  ./hermes --telegram   - Start Telegram gateway")
  (println "  ./hermes --discord    - Start Discord gateway")
  (println "  ./hermes --a2a        - Start A2A Protocol server")
  (println "  ./hermes --resume <id>- Resume a past session")
  (println "  ./hermes --help, -h   - Show this help message"))

(defn run-gleam [args]
  (let [root-dir (fs/parent *file*)
        beam-dir (str (fs/path root-dir "hermes_beam"))]
    (if (fs/exists? (fs/path beam-dir "gleam.toml"))
      (let [res (apply proc/process {:dir beam-dir :inherit true} "gleam" "run" "--" args)]
        (System/exit (:exit @res)))
      (do
        (binding [*out* *err*]
          (println "Error: Gleam project not found at" beam-dir))
        (System/exit 1)))))

(defn -main [args]
  (let [first-arg (first args)]
    (cond
      (or (= first-arg "--help") (= first-arg "-h") (= first-arg "help"))
      (print-help)

      :else
      (run-gleam args))))

(-main *command-line-args*)
